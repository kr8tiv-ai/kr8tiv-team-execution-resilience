{
  "agent_name": "ARSENAL",
  "role": "reliability_and_security_deputy",
  "model": {
    "primary": "codex-cli/gpt-5.3-codex",
    "fallbacks": ["openai-codex/gpt-5.3-codex"],
    "providerLock": "openai-codex"
  },
  "reasoningPolicy": {
    "default": "max",
    "fallbackBehavior": "highest_or_model_default"
  },
  "persona": {
    "presetRef": "arsenal-reliability",
    "mode": "team",
    "orchestratorEnabled": true
  },
  "onboarding": {
    "recommendationEnabled": true,
    "personalizedDefaults": ["voice", "uplay_chromium"],
    "autoNotebooklmPrompt": true
  },
  "channels": {
    "telegram": {
      "botToken": "__INJECT_AT_RUNTIME__"
    }
  },
  "secret_policy": "No keys in git"
}

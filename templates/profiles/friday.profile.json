{
  "agent_name": "FRIDAY",
  "role": "lead_orchestrator",
  "model": {
    "primary": "claude-cli/claude-opus-4-6",
    "fallbacks": ["anthropic/claude-opus-4-6"],
    "providerLock": "anthropic"
  },
  "reasoningPolicy": {
    "default": "max",
    "fallbackBehavior": "highest_or_model_default"
  },
  "persona": {
    "presetRef": "friday-cmo",
    "mode": "team",
    "orchestratorEnabled": true
  },
  "onboarding": {
    "recommendationEnabled": true,
    "personalizedDefaults": ["voice", "uplay_chromium"],
    "autoNotebooklmPrompt": true
  },
  "channels": {
    "telegram": {
      "botToken": "__INJECT_AT_RUNTIME__"
    }
  },
  "secret_policy": "No keys in git"
}
